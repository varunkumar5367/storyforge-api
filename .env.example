# Required API Keys
GROQ_API_KEY=your_groq_api_key_here

# Image generation — Provider 1 (primary): Google Gemini
# Free tier: 2 images/min. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Image generation — Provider 2 (first fallback): Hugging Face FLUX.1-schnell
# Get a free token at https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Image generation — Provider 3 (last fallback): Pollinations.ai
# Optional — only used when Gemini and Hugging Face both fail
POLLINATIONS_API_KEY=your_pollinations_api_key_here

# Backend configuration
VOICEFORGE_URL=https://voiceforge-pzxd.onrender.com
OUTPUT_DIR=./output
DATABASE_URL=./storyforge.db
FRONTEND_URL=http://localhost:3000
