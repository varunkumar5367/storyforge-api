# =============================================================================
# StoryForge AI — Backend Environment Configuration
# Copy to .env and fill in all required values.
# =============================================================================

# ── Required ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=
JWT_SECRET_KEY=
DATABASE_URL=

# Supabase PostgreSQL example:
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── URLs (required for production / Cloudflare Tunnel) ────────────────────────
FRONTEND_URL=
BACKEND_PUBLIC_URL=

# Production examples:
# FRONTEND_URL=https://your-app.vercel.app
# BACKEND_PUBLIC_URL=https://api.yourdomain.com

# ── Cloudinary (optional — CDN for finished assets) ───────────────────────────
CLOUDINARY_URL=

# ── Supabase Storage (optional — CDN for finished assets) ─────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=

# ── Runtime ───────────────────────────────────────────────────────────────────
ENV=development
OUTPUT_DIR=./output
PORT=8000

# Set ENV=production when serving via Cloudflare Tunnel + Vercel frontend

# ── TTS (optional — edge-tts is used locally when installed) ────────────────
VOICEFORGE_URL=

# ── Image generation (optional — fallback chain) ──────────────────────────────
GEMINI_API_KEY=
HUGGINGFACE_API_KEY=
POLLINATIONS_API_KEY=

# ── FFmpeg tuning (laptop hosting — 4 threads recommended; benchmark with scratch/benchmark_ffmpeg_threads.py) ──
FFMPEG_THREADS=4

# ── Legacy alias (JWT_SECRET_KEY preferred) ───────────────────────────────────
# JWT_SECRET=

# ── Local GPU & Models Configuration ──────────────────────────────────────────
# Set to true to bypass cloud API endpoints and execute models locally on RTX GPU
USE_LOCAL_LLM=false
USE_LOCAL_IMAGES=false
USE_LOCAL_WHISPER=false

# Ollama local endpoint configuration (OpenAI-compatible)
OLLAMA_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b-instruct

# Local Hugging Face / Diffusers configurations
LOCAL_IMAGE_MODEL=ByteDance/SDXL-Lightning-4step
LOCAL_WHISPER_MODEL=small

# Cache directories for models (recommended on large secondary drives)
HF_HOME=E:\huggingface_cache
OLLAMA_MODELS=E:\OllamaModels
PIP_CACHE_DIR=E:\pip_cache
